    <div class="event-card promo-card book-card">
      <div class="event-card-body">
        <span class="event-type-badge">SAY HELLO</span>

        <div class="contact-quick">
          <a class="btn btn-primary contact-wa-btn" href="{{ social.whatsappArjun }}" target="_blank" rel="noopener">Chat on WhatsApp</a>
          <a class="btn btn-ghost" href="{{ social.whatsapp }}" target="_blank" rel="noopener">Join the WhatsApp Community</a>
        </div>

        <form class="contact-form" action="/submit" method="post">
          {# Tells the Pages Function which Google Form to forward to after it
             verifies the Turnstile token. #}
          <input type="hidden" name="form" value="contact">

          <div class="contact-field">
            <label for="cf-name">Your name</label>
            <input id="cf-name" name="{{ entryName }}" type="text" autocomplete="name" required>
          </div>

          <div class="contact-field">
            <label for="cf-whatsapp">WhatsApp number</label>
            <input id="cf-whatsapp" name="{{ entryWhatsapp }}" type="tel" autocomplete="tel" inputmode="tel" placeholder="+91...">
          </div>

          <div class="contact-field">
            <label for="cf-email">Email</label>
            <input id="cf-email" name="{{ entryEmail }}" type="email" autocomplete="email" required>
          </div>

          <div class="contact-field">
            <label for="cf-preferred">Preferred way to reach you</label>
            <select id="cf-preferred" name="{{ entryPreferred }}" required>
              <option value="" disabled selected>How should we reach you?</option>
              <option value="Whatsapp">WhatsApp</option>
              <option value="Email">Email</option>
              <option value="Phone call">Phone call</option>
            </select>
          </div>

          <div class="contact-field">
            <label for="cf-topic">What's this about?</label>
            <select id="cf-topic" name="{{ entryTopic }}" required>
              <option value="" disabled selected>Pick a topic</option>
              <option value="General Question">General question</option>
              <option value="Perform with us">Perform with us</option>
              <option value="Workshop info">Workshop info</option>
              <option value="Invite us to perform">Invite us to perform</option>
              <option value="Corporate or team events">Corporate or team events</option>
              <option value="Something else">Something else</option>
            </select>
          </div>

          <div class="contact-field">
            <label for="cf-message">Message</label>
            <textarea id="cf-message" name="{{ entryMessage }}" rows="5" required></textarea>
          </div>

          {# Cloudflare Turnstile widget. The token it produces is read from the
             auto-injected cf-turnstile-response field and verified server-side
             by functions/submit.js before anything reaches the Google Form. #}
          <div class="cf-turnstile contact-turnstile"
               data-sitekey="{{ site.turnstileSiteKey }}"
               data-action="contact"
               data-theme="light"></div>

          <div class="event-buttons">
            <button class="btn btn-primary" type="submit">Send message</button>
          </div>

          <p class="contact-error" role="alert" aria-live="assertive" hidden></p>
          <p class="contact-status" role="status" aria-live="polite" hidden>Thanks. We've got your message and will be in touch soon.</p>
        </form>

      </div>
    </div>

  </section>

</div>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
<script>
  // The form POSTs to our own /submit Pages Function, which verifies the
  // Turnstile token server-side and only then forwards the fields to the Google
  // Form. Because /submit is same-origin, we CAN read its JSON response (unlike
  // the old direct, opaque no-cors POST to Google), so success and failure are
  // both detectable. If /submit is unreachable (offline, deploy down) we fall
  // back to opening the user's mail client pre-filled with the message, so the
  // enquiry isn't lost. Native validation (no novalidate) still gates required
  // fields; we run reportValidity() before sending.
  // Prefill from URL params. A dead ticket button (sold out / coming soon)
  // links here with ?topic=&message= so the visitor lands on a started enquiry
  // about that specific event instead of a blank form. Only known fields are
  // touched, and a select value is applied only if it's a real option.
  (function () {
    const params = new URLSearchParams(window.location.search);
    if (![...params.keys()].length) return;

    const setInput = (id, value) => {
      const el = document.getElementById(id);
      if (el && value) el.value = value;
    };
    const setSelect = (id, value) => {
      const el = document.getElementById(id);
      if (el && value && [...el.options].some((o) => o.value === value)) {
        el.value = value;
      }
    };

    setSelect("cf-topic", params.get("topic"));
    setInput("cf-message", params.get("message"));
  })();

  (function () {
    const form = document.querySelector(".contact-form");
    if (!form) return;
    const status = form.querySelector(".contact-status");
    const errorBox = form.querySelector(".contact-error");
    const button = form.querySelector('button[type="submit"]');
    const action = form.getAttribute("action");
    const FALLBACK_EMAIL = "{{ social.gmail | replace('mailto:', '') | replace('@', '\" + \"@\" + \"') | safe }}";

    // Reset the Turnstile widget so a fresh token is required for the next try
    // (tokens are single-use). turnstile may not be loaded yet; guard for it.
    const resetTurnstile = () => {
      if (window.turnstile) {
        try { window.turnstile.reset(); } catch (e) {}
      }
    };

    const showError = (msg) => {
      if (!errorBox) return;
      errorBox.textContent = msg;
      errorBox.hidden = false;
    };
    const clearError = () => {
      if (errorBox) errorBox.hidden = true;
    };

    // Read the human-readable values by their stable ids (not the entry.* names).
    const readForm = () => ({
      name:      (document.getElementById("cf-name")      || {}).value || "",
      whatsapp:  (document.getElementById("cf-whatsapp")  || {}).value || "",
      email:     (document.getElementById("cf-email")     || {}).value || "",
      preferred: (document.getElementById("cf-preferred") || {}).value || "",
      topic:     (document.getElementById("cf-topic")     || {}).value || "",
      message:   (document.getElementById("cf-message")   || {}).value || "",
    });

    // Plain-text (non-JSON) email body for the contact enquiry.
    const emailFallback = (data) => {
      const subject = "Website enquiry: " + (data.topic || "general") + " from " + (data.name || "someone");
      const lines = [
        "The website couldn't reach the contact form, so here's the enquiry:",
        "",
        "Name: " + data.name,
        "WhatsApp: " + (data.whatsapp || "-"),
        "Email: " + data.email,
        "Preferred contact: " + data.preferred,
        "About: " + data.topic,
        "",
        "Message:",
        data.message,
      ];
      const href = "mail" + "to:" + FALLBACK_EMAIL +
        "?subject=" + encodeURIComponent(subject) +
        "&body=" + encodeURIComponent(lines.join("\n"));
      window.location.href = href;
    };

    const showSent = () => {
      if (status) status.hidden = false;
      form.reset();
      resetTurnstile();
    };

    form.addEventListener("submit", async function (e) {
      e.preventDefault();
      clearError();
      if (!form.reportValidity()) return;

      // Require a Turnstile token before we even hit the network. The widget
      // injects it as cf-turnstile-response; if it's empty the user hasn't
      // solved (or the script hasn't loaded) yet.
      const formData = new FormData(form);
      if (!formData.get("cf-turnstile-response")) {
        showError("Please complete the verification above, then send again.");
        return;
      }

      const data = readForm();
      if (button) {
        button.disabled = true;
        button.textContent = "Sending...";
      }

      try {
        const resp = await fetch(action, {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body: new URLSearchParams(formData).toString(),
        });
        const result = await resp.json().catch(() => ({}));

        if (resp.ok && result.ok) {
          showSent();
        } else if (result.error === "turnstile_failed" || result.error === "missing_token") {
          // The verification didn't pass. Make the user solve it again; do not
          // fall back to email, since this is the bot gate doing its job.
          showError("Verification failed. Please complete the check and try again.");
          resetTurnstile();
        } else {
          // Server reached us but couldn't forward (Google Form down, config
          // error). Hand the enquiry to the mail client so it isn't lost.
          console.error("Contact submit failed:", result);
          emailFallback(data);
          showSent();
        }
      } catch (err) {
        // /submit unreachable (offline, deploy down): email fallback.
        console.error("Contact form unreachable, using email fallback:", err);
        emailFallback(data);
        showSent();
      } finally {
        if (button) {
          button.disabled = false;
          button.textContent = "Send message";
        }
      }
    });
  })();
</script>
