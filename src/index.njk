---
layout: base.njk
title: Improvlore – Upcoming Shows
showCustomEvents: false
---

<div class="events-root">

  <section class="page-section" aria-labelledby="section-whats-on">
    <h2 class="section-heading" id="section-whats-on">What's On</h2>
    <p class="section-sub">Check out our upcoming events below. The friendliest way to get started with improv.</p>

  {% set weekEvents = filters.upcomingWeek(events, showCustomEvents) %}
  {% if weekEvents.length %}
  <details class="week-view" aria-label="Upcoming week" open>
    <summary class="week-view-title">
      <span>{% if filters.spansBeyondThisWeek(weekEvents) %}Upcoming{% else %}This Week{% endif %}</span>
      <span class="week-view-chevron" aria-hidden="true">▾</span>
    </summary>
    <ul class="week-list">
      {% for ev in weekEvents %}
        {% set evType = filters.eventType(ev.title, ev.tags) %}
        <li class="week-item event-type-{{ evType }}">
          <a class="week-item-link" href="#{{ filters.eventSlug(ev) }}">
            <div class="week-date">
              <span class="week-day">{{ filters.formatDay(ev.event_starts_at) }}</span>
              <span class="week-daynum">{{ filters.formatDayNum(ev.event_starts_at) }}</span>
              <span class="week-month">{{ filters.formatMonth(ev.event_starts_at) }}</span>
            </div>
            <div class="week-info">
              <span class="week-time">{{ filters.formatTime(ev.event_starts_at) }}</span>
              <span class="week-name">{{ ev.title }}</span>
              <span class="week-type-tag week-type-{{ evType }}">{{ evType }}</span>
            </div>
          </a>
        </li>
      {% endfor %}
    </ul>
  </details>
  {% endif %}

  <div class="event-key" role="group" aria-label="Filter events by type">
    <button type="button" class="event-key-item" data-filter="show" aria-pressed="false">
      <span class="event-key-dot dot-show"></span>
      <div>
        <strong>SHOW</strong>
        <p>You shape the show with us</p>
      </div>
    </button>
    <button type="button" class="event-key-item" data-filter="jam" aria-pressed="false">
      <span class="event-key-dot dot-jam"></span>
      <div>
        <strong>JAM</strong>
        <p>Come play with us, beginner friendly</p>
      </div>
    </button>
    <button type="button" class="event-key-clear" data-filter-clear hidden aria-label="Clear filter">
      <span aria-hidden="true">×</span> Clear
    </button>
  </div>

  <div class="filter-empty" hidden>
    <h2>No <span class="filter-empty-type">events</span> coming up</h2>
    <p>Nothing of that kind on the calendar right now. Try the other type or clear the filter.</p>
  </div>

  {% for ev in events %}
  {% if (showCustomEvents or (ev.tags and "UC" in ev.tags)) and filters.eventType(ev.title, ev.tags) != "workshop" %}
    {% set dateLabel = "" %}
    {% if ev.event_starts_at %}
      {% set dateLabel = filters.formatDate(ev.event_starts_at) ~ " · " ~ filters.formatTime(ev.event_starts_at) %}
    {% endif %}

    {% set img = null %}
    {% if ev.thumbnails and ev.thumbnails.length %}
      {% set img = ev.thumbnails[0].url %}
    {% elif ev.image_url %}
      {% set img = ev.image_url %}
    {% endif %}

    {% set evType = filters.eventType(ev.title, ev.tags) %}
    <div id="{{ filters.eventSlug(ev) }}" class="event-flip event-type-{{ evType }}">
      <div class="event-flip-inner">

        <div class="event-card event-flip-face event-flip-front event-type-{{ evType }}">

          {% if img %}
            <div class="event-image">
              <img src="{{ img }}" alt="{{ ev.title }}">
            </div>
          {% endif %}

          <div class="event-card-body">
            <span class="event-type-badge">{{ evType }}</span>
            <h2 class="event-title">{{ ev.title }}</h2>

            {% if dateLabel %}
              <div class="event-date">{{ dateLabel }} — {{ ev.venue }}</div>
            {% endif %}

            <p class="event-excerpt">
              {{ filters.shortText(ev.excerpt or ev.full_content, 180) }}
            </p>

            <div class="event-buttons">
              <a class="btn btn-primary" href="{{ ev.url }}" target="_blank">Buy Ticket</a>
              <a class="btn btn-ghost" href="{{ ev.learn_more }}" target="_blank">Learn More</a>
            </div>
          </div>

          <button type="button" class="event-flip-trigger" aria-label="What to expect">
            <span>What to expect</span>
            <span aria-hidden="true">↻</span>
          </button>
        </div>

        <div class="event-card event-flip-face event-flip-back event-type-{{ evType }}">
          <div class="event-card-body">
            <span class="event-type-badge">{{ evType }}</span>
            <h2 class="event-title">{{ ev.title }}</h2>

            {% if dateLabel %}
              <div class="event-date">{{ dateLabel }} — {{ ev.venue }}</div>
            {% endif %}

            <div class="event-expect-body">
              {% if evType == "jam" %}
                <p>Jams are our open sessions for anyone curious about improv.</p>
                <p><strong>Whimsical Wednesday</strong> is off-stage play. Low-pressure exercises, no audience, a great place to start and meet people.</p>
                <p><strong>Make Friends with the Stage</strong> is the next step on-stage. Short scenes in a supportive room, designed to help you take the leap into performing.</p>
              {% else %}
                <p>A live improv performance built entirely from your suggestions.</p>
                <p>Every show is a one-time-only piece of theatre, created in the moment, in front of you.</p>
                <p>Some of our shows are themed or follow a particular format. Theme or no theme, each show is one of a kind. Tap <strong>Learn More</strong> for the specifics of this one.</p>
              {% endif %}
            </div>

            <div class="event-buttons">
              <a class="btn btn-primary" href="{{ ev.url }}" target="_blank">Buy Ticket</a>
              <a class="btn btn-ghost" href="{{ ev.learn_more }}" target="_blank">Learn More</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  {% endif %}
  {% endfor %}

  </section>

  <section class="page-section page-section-info" aria-labelledby="section-book-visit">
    <h2 class="section-heading" id="section-book-visit">Book &amp; Visit</h2>

  <div class="event-card promo-card book-card">
    <div class="event-card-body">
      <span class="event-type-badge">BOOK US</span>
      <h2 class="event-title">Bring improv to your workplace</h2>
      <p class="event-excerpt">Custom shows and workshops, shaped around your team's goals. Whether it's an offsite, a team-building day, or a company event, we'll build something that fits.</p>

      <ul class="book-offer-list">
        <li>
          <span class="book-offer-icon" aria-hidden="true">🎭</span>
          <div>
            <strong>Custom Shows</strong>
            <p>A private improv show tailored to your team, theme, or occasion.</p>
          </div>
        </li>
        <li>
          <span class="book-offer-icon" aria-hidden="true">🧩</span>
          <div>
            <strong>Team Workshops</strong>
            <p>Hands-on sessions that build trust, listening, and collaboration through play.</p>
          </div>
        </li>
      </ul>

      <p class="book-cta-line">Tell us a bit about your team and we'll design something specific.</p>

      <div class="event-buttons">
        <a class="btn btn-primary" href="mailto:{{ social.gmail | replace('mailto:', '') }}?subject=Book Improvlore for our team">Email Us</a>
        <a class="btn btn-ghost" href="{{ social.instagram }}" target="_blank">DM on Instagram</a>
      </div>
    </div>
  </div>

  <div class="event-card promo-card workshop-card">
    <div class="event-card-body">
      <span class="event-type-badge">WORKSHOPS</span>
      <h2 class="event-title">Learn improv with us</h2>
      <p class="event-excerpt">We run regular workshops for anyone curious about improv. No experience needed, just a willingness to play.</p>

      <ul class="book-offer-list">
        <li>
          <span class="book-offer-icon" aria-hidden="true">🌱</span>
          <div>
            <strong>Improv 101</strong>
            <p>The fundamentals: listening, yes-and, and getting comfortable on your feet.</p>
          </div>
        </li>
        <li>
          <span class="book-offer-icon" aria-hidden="true">🎵</span>
          <div>
            <strong>Musical Improv</strong>
            <p>Make songs up on the spot. Group numbers, solos, and a lot of laughing.</p>
          </div>
        </li>
      </ul>

      <p class="book-cta-line">Next batch dates aren't out yet. Drop your details and we'll let you know.</p>

      <div class="event-buttons">
        <a class="btn btn-primary" href="https://docs.google.com/forms/d/e/1FAIpQLScVGlLUHvSgII5k7CeEijb48vaqdK9OcHr0Awx6KKIiHDujog/viewform" target="_blank" rel="noopener">Notify Me</a>
        <a class="btn btn-ghost" href="{{ social.instagram }}" target="_blank">DM on Instagram</a>
      </div>
    </div>
  </div>

  <div class="event-card promo-card">
    <div class="event-card-body">
      <h2 class="event-title">More events in Bangalore?</h2>
      <p class="event-excerpt">Underline Center is a community space in Indiranagar that hosts shows, workshops, and events all year round. Check out what else is on.</p>
      <div class="event-buttons">
        <a class="btn btn-primary" href="https://underline.center" target="_blank">Visit Underline Center</a>
        <a class="btn btn-ghost" href="https://www.google.com/maps/place/Underline+Center/@12.9672266,77.6341233,1247m/data=!3m2!1e3!4b1!4m6!3m5!1s0x3bae15ce8263b8d9:0x1589e99864d3e1a8!8m2!3d12.9672214!4d77.6366982!16s%2Fg%2F11vqhpphq2?entry=ttu&g_ep=EgoyMDI2MDUwNi4wIKXMDSoASAFQAw%3D%3D" target="_blank">View on Maps</a>
      </div>
    </div>
  </div>

  </section>

</div>
