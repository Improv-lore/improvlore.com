---
layout: base.njk
title: Improvlore - Bangalore
showCustomEvents: false
requiresEvents: true
---

<div class="events-root">

  {# Hero rotates through upcoming workshops; if none are scheduled, it falls
     back to upcoming jams. Slides auto-advance every 10s (see base.njk script). #}
  {% set heroWorkshops = filters.upcomingWorkshops(events, showCustomEvents) %}
  {% if heroWorkshops.length %}
    {% set heroSlides = heroWorkshops %}
    {% set heroKicker = "Workshop coming up" %}
  {% else %}
    {% set heroSlides = filters.upcomingJams(events, showCustomEvents) %}
    {% set heroKicker = "Jam coming up" %}
  {% endif %}

  {% if heroSlides.length %}
  <div class="hero-feature-carousel" data-hero-carousel data-hero-interval="10000" aria-roledescription="carousel" aria-label="What to come to next">
    {% for ev in heroSlides %}
    <a class="hero-feature{% if loop.first %} is-active{% endif %}" href="{{ filters.eventPermalink(ev) }}" data-hero-slide aria-hidden="{{ "false" if loop.first else "true" }}"{% if not loop.first %} tabindex="-1"{% endif %}>
      <img class="hero-feature-poster" src="{{ filters.eventImage(ev) }}" alt="{{ ev.title }} poster" loading="{% if loop.first %}eager{% else %}lazy{% endif %}">
      <span class="hero-feature-body">
        <span class="hero-feature-kicker">{{ heroKicker }}</span>
        <span class="hero-feature-title">{{ filters.workshopName(ev.title) }}</span>
        <span class="hero-feature-blurb">{{ filters.formatDay(ev.event_starts_at) }}, {{ filters.formatDayNum(ev.event_starts_at) }} {{ filters.formatMonth(ev.event_starts_at) }} at {{ filters.formatTime(ev.event_starts_at) }}</span>
      </span>
    </a>
    {% endfor %}
    {% if heroSlides.length > 1 %}
    <div class="hero-feature-dots" role="tablist" aria-label="Choose slide">
      {% for ev in heroSlides %}
      <button type="button" class="hero-feature-dot{% if loop.first %} is-active{% endif %}" data-hero-dot data-hero-index="{{ loop.index0 }}" aria-label="Show slide {{ loop.index }}"{% if loop.first %} aria-selected="true"{% else %} aria-selected="false"{% endif %}></button>
      {% endfor %}
    </div>
    {% endif %}
  </div>
  {% endif %}

  <section class="page-section" aria-labelledby="section-whats-on">
    <h2 class="section-heading" id="section-whats-on">What's On</h2>
    <p class="section-sub">The next few nights at a glance. Tap any one for details and tickets.</p>

  <div class="boards-row">

  {% set weekEvents = filters.upcomingWeek(events, showCustomEvents) %}
  {% if weekEvents.length %}
  <details class="week-view" aria-label="Upcoming shows and jams" open>
    <summary class="week-view-title">
      <span>{% if filters.spansBeyondThisWeek(weekEvents) %}Shows &amp; Jams Coming Up{% else %}Shows &amp; Jams This Week{% endif %}</span>
      <span class="week-view-chevron" aria-hidden="true">▾</span>
    </summary>
    <ul class="week-list">
      {% for ev in weekEvents %}
        {% set evType = filters.eventType(ev.title, ev.tags) %}
        <li class="week-item event-type-{{ evType }}">
          <a class="week-item-link" href="{{ filters.eventPermalink(ev) }}">
            <div class="week-date">
              <span class="week-day">{{ filters.formatDay(ev.event_starts_at) }}</span>
              <span class="week-daynum">{{ filters.formatDayNum(ev.event_starts_at) }}</span>
              <span class="week-month">{{ filters.formatMonth(ev.event_starts_at) }}</span>
            </div>
            <div class="week-info">
              <span class="week-time">{{ filters.formatTime(ev.event_starts_at) }}</span>
              <span class="week-name">{{ ev.title }}</span>
              <span class="week-type-tag week-type-{{ evType }}">{{ evType }}</span>
            </div>
          </a>
        </li>
      {% endfor %}
    </ul>
  </details>
  {% endif %}

  </div>

  <p class="see-all-line">
    <a class="see-all-link" href="/events/">See all events →</a>
  </p>

  </section>

  <section class="page-section" aria-labelledby="section-start">
    <h2 class="section-heading" id="section-start">New Here? Start Anywhere</h2>
    <p class="section-sub">However you like to play, there's a way in. We just want you to find joy in play again.</p>

    <ul class="book-offer-list about-paths">
      <li>
        <a class="about-path-link" href="/events/?type=show">
          <strong>Watch a show</strong>
          <p>Sit back and let us build a one-time-only show from your suggestions. No pressure to do a thing.</p>
        </a>
      </li>
      <li>
        <a class="about-path-link" href="/events/?type=jam">
          <strong>Play at a jam</strong>
          <p>Our open, beginner-friendly sessions. Jump in, mess around, meet people. No experience needed.</p>
        </a>
      </li>
      <li>
        <a class="about-path-link" href="/events/?type=workshop">
          <strong>Take a workshop</strong>
          <p>Learn by doing, at a pace that's kind to first-timers. A guided room where it's safe to try.</p>
        </a>
      </li>
    </ul>

    <p class="book-cta-line">Pricing and venue are listed on each event, so you always know before you go.</p>
  </section>

  <section class="page-section" aria-labelledby="section-about">
    <h2 class="section-heading" id="section-about">Who We Are</h2>

    <div class="about-intro">
      <p class="about-lede">We make up theatre on the spot, with no script and no second take. Around since 2022, making people laugh at stories that never existed before and never will again.</p>
    </div>

    <p class="more-line">
      Weekly jams, workshops, and shows built live from whatever the room gives us.
      <a href="/about/">Read our story →</a>
    </p>
  </section>

  <section class="page-section" aria-labelledby="section-shows">
    <h2 class="section-heading" id="section-shows">Shows We Are Known For</h2>
    <p class="section-sub">Built live from what the room gives us, so no two are the same. A few of the formats we keep coming back to.</p>

    <ul class="about-shows" aria-label="Signature show formats">
      {% for show in signatureShows %}
      <li>
        <a class="about-show-card" href="{{ show.url }}" target="_blank" rel="noopener">
          <img class="about-show-poster" src="{{ show.image }}" alt="{{ show.title }} poster" loading="lazy">
          <div class="about-show-body">
            <strong>{{ show.title }}</strong>
            <span>{{ show.blurb }}</span>
          </div>
        </a>
      </li>
      {% endfor %}
    </ul>
  </section>

  <section class="page-section page-section-info" aria-labelledby="section-more">
    <h2 class="section-heading" id="section-more">More From Us</h2>

    <a class="corporate-banner" href="/for-teams/">
      <span class="corporate-banner-text">
        <strong>We bring improv to workplaces too.</strong>
        Custom shows and team workshops, shaped around your team.
      </span>
      <span class="corporate-banner-arrow" aria-hidden="true">→</span>
    </a>

    
  </section>

</div>
