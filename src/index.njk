---
layout: base.njk
title: Improvlore – Upcoming Shows
showCustomEvents: false
---

<div class="events-root">

  {% for ev in events %}
  {% if showCustomEvents or (ev.tags and "UC" in ev.tags) %}
    {% set dateLabel = "" %}
    {% if ev.event_starts_at %}
      {% set dateLabel = filters.formatDate(ev.event_starts_at) ~ " · " ~ filters.formatTime(ev.event_starts_at) %}
    {% endif %}

    {% set img = null %}
    {% if ev.thumbnails and ev.thumbnails.length %}
      {% set img = ev.thumbnails[0].url %}
    {% elif ev.image_url %}
      {% set img = ev.image_url %}
    {% endif %}

    <div class="event-card">

      {% if img %}
        <div class="event-image">
          <img src="{{ img }}" alt="{{ ev.title }}">
        </div>
      {% endif %}

      <h2 class="event-title">{{ ev.title }}</h2>

      {% if dateLabel %}
        <div class="event-date">{{ dateLabel }} — {{ ev.venue }}</div>
      {% endif %}

      <p class="event-excerpt">
        {{ filters.shortText(ev.excerpt or ev.full_content, 180) }}
      </p>

      <div class="event-buttons">
        <a class="btn btn-primary" href="{{ ev.url }}" target="_blank">Buy Ticket</a>
        <a class="btn btn-ghost" href="{{ ev.learn_more }}" target="_blank">Learn More</a>
      </div>

    </div>
  {% endif %}
  {% endfor %}

</div>
