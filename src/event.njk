---
layout: base.njk
pagination:
  data: events
  size: 1
  alias: ev
---

{% set evType = filters.eventType(ev.title, ev.tags) %}

{% if evType == "jam" %}
  {% set expectCopy = "Jams are our open sessions for anyone curious about improv. Low-pressure, beginner friendly, and a great place to meet people." %}
{% elif evType == "workshop" %}
  {% set expectCopy = "A hands-on session to learn improv by doing, no experience needed. You'll work through guided exercises in a supportive room, at a pace that's friendly to first-timers." %}
{% else %}
  {% set expectCopy = "A live improv performance built entirely from your suggestions. Every show is a one-time-only piece of theatre, created in the moment, in front of you." %}
{% endif %}

{% set bodyText = ev.full_content or ev.excerpt or "" %}
{% set d = {
  type: evType,
  image: filters.eventImage(ev),
  title: ev.title,
  hasWhen: ev.event_starts_at,
  startsAt: filters.formatDateFull(ev.event_starts_at),
  timeRange: filters.formatTimeRange(ev.event_starts_at, ev.event_ends_at),
  venue: ev.venue,
  bodyParas: bodyText.split("\n"),
  expect: expectCopy,
  ticketUrl: ev.url,
  learnMore: ev.learn_more
} %}

{% include "event-detail.njk" %}
