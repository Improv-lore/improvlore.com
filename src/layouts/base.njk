   <hr>
<p class="tagline">Hi!👋 <br> We're Bangalore's friendliest improv troupe. <br>We take play, seriously.</p>
 
  
    <H2>UPCOMING EVENTS👇</H2>
</div>


  <main>
    {% if events.length > 0 %}
      {{ content | safe }}
     
  
    {% else %}
    
      <div class="empty-state">
        <h2>No upcoming events</h2>
        <p>join our socials in the meantime!</p>
        <p class="warning">if you think this is an error please contact us.</p>
      </div>
    {% endif %}
  </main>

