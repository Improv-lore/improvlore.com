<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  {% if pageDescription %}<meta name="description" content="{{ pageDescription }}">{% endif %}
  <meta property="og:title" content="{{ title }}">
  {% if pageDescription %}<meta property="og:description" content="{{ pageDescription }}">{% endif %}
  {% if pageImage %}<meta property="og:image" content="{{ pageImage }}">{% endif %}
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="{% if pageImage %}summary_large_image{% else %}summary{% endif %}">
  <link rel="stylesheet" href="/assets/events.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>
  <div class="page-motifs" aria-hidden="true">
    <img class="motif motif-1"  src="/assets/icons/lightning.png"     alt="">
    <img class="motif motif-2"  src="/assets/icons/starburst.png"     alt="">
    <img class="motif motif-3"  src="/assets/icons/star-purple.png"   alt="">
    <img class="motif motif-4"  src="/assets/icons/diamond.png"       alt="">
    <img class="motif motif-5"  src="/assets/icons/star-4point.png"   alt="">
    <img class="motif motif-6"  src="/assets/icons/moon.png"          alt="">
    <img class="motif motif-7"  src="/assets/icons/star-green.png"    alt="">
    <img class="motif motif-8"  src="/assets/icons/ring-pink.png"     alt="">
    <img class="motif motif-9"  src="/assets/icons/star-outline.png"  alt="">
    <img class="motif motif-10" src="/assets/icons/arc-blue.png"      alt="">
    <img class="motif motif-11" src="/assets/icons/arc-green.png"     alt="">
    <img class="motif motif-12" src="/assets/icons/arc-pink.png"      alt="">
    <img class="motif motif-13" src="/assets/icons/pacman-orange.png" alt="">
    <img class="motif motif-14" src="/assets/icons/pacman-yellow.png" alt="">
    <img class="motif motif-15" src="/assets/icons/blob-blue.png"     alt="">
    <img class="motif motif-16" src="/assets/icons/blob-cream.png"    alt="">
  </div>

  <div class="foreground-motifs" aria-hidden="true">
    <img class="fg-motif fg-motif-lightning" src="/assets/icons/lightning.png"     alt="">
    <img class="fg-motif fg-motif-pacman"    src="/assets/icons/pacman-yellow.png" alt="">
  </div>

  <div class="page-hero">
    <a class="hero-logo-link" href="/" aria-label="Improv Lore home">
      <img class="hero-logo" src="/assets/logo.png" alt="Improv Lore">
    </a>

    <p class="tagline">Bangalore's friendliest improv troupe. <br>We take play, seriously.</p>

    <div class="hero-cta">
      <a class="btn btn-primary hero-cta-btn" href="/events/">See What's On →</a>
    </div>

    <div class="social-row">
      <a class="social-icon social-icon-attn social-icon-attn-1" href="{{ social.whatsapp }}" target="_blank">
        <img src="/assets/icons/whatsapp.svg" alt="WhatsApp">
      </a>
      <a class="social-icon social-icon-attn social-icon-attn-2" href="{{ social.instagram }}" target="_blank">
        <img src="/assets/icons/instagram.svg" alt="Instagram">
      </a>
      <a class="social-icon" href="{{ social.youtube }}" target="_blank">
        <img src="/assets/icons/youtube.svg" alt="YouTube">
      </a>
      <a class="social-icon" href="{{ social.gmail }}" target="_blank">
        <img src="/assets/icons/gmail.svg" alt="Gmail">
      </a>
    </div>

  </div>

  <main>
    {% if events.length > 0 or not requiresEvents %}
      {{ content | safe }}
    {% else %}
      <div class="empty-state">
        <h2>No upcoming events</h2>
        <p>join our socials in the meantime!</p>
        <p class="warning">if you think this is an error please contact us.</p>
      </div>
    {% endif %}
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <nav class="footer-nav" aria-label="Footer">
        <a href="/">Home</a>
        <a href="/about/">About</a>
        <a href="/events/">All Events</a>
        <a href="/for-teams/">For Teams</a>
        <a href="https://underline.center" target="_blank" rel="noopener">Underline Center ↗</a>
      </nav>

      <div class="footer-social" aria-label="Social links">
        <a href="{{ social.instagram }}" target="_blank" rel="noopener">Instagram</a>
        <a href="{{ social.whatsapp }}" target="_blank" rel="noopener">WhatsApp</a>
        <a href="{{ social.youtube }}" target="_blank" rel="noopener">YouTube</a>
        <a href="{{ social.gmail }}">Email</a>
      </div>

      <div class="footer-legal">
        <p>&copy; {{ site.year }} Improvlore. All rights reserved.</p>
        <p>Based in Bangalore, India. Questions? <a href="{{ social.gmail }}?subject=Improvlore website enquiry">{{ social.gmail | replace('mailto:', '') }}</a></p>
      </div>
    </div>
  </footer>

  <script>
    document.addEventListener("click", (e) => {
      const link = e.target.closest(".week-item-link");
      if (!link) return;
      const details = link.closest("details.week-view");
      if (details) details.open = false;
    });

    const applyFilter = (filter) => {
      const root = document.querySelector(".events-root");
      if (!root) return;
      root.querySelectorAll(".event-key-item[data-filter]").forEach((b) => {
        b.setAttribute("aria-pressed", b.dataset.filter === filter ? "true" : "false");
      });
      root.classList.remove("filter-show", "filter-jam", "filter-workshop");
      const clearBtn = root.querySelector("[data-filter-clear]");
      const empty = root.querySelector(".filter-empty");
      const weekView = root.querySelector("details.week-view");
      if (filter) {
        root.classList.add("filter-" + filter);
        if (weekView) weekView.open = false;
        if (clearBtn) clearBtn.hidden = false;
        if (empty) {
          const visibleCards = root.querySelectorAll(
            ".event-flip.event-type-" + filter
          ).length;
          empty.hidden = visibleCards > 0;
          const label = empty.querySelector(".filter-empty-type");
          if (label) label.textContent = filter + "s";
        }
      } else {
        if (clearBtn) clearBtn.hidden = true;
        if (empty) empty.hidden = true;
      }
    };

    // Hero carousel: auto-advance every data-hero-interval ms, pause on hover,
    // and let the dots jump to a slide.
    document.querySelectorAll("[data-hero-carousel]").forEach((carousel) => {
      const slides = [...carousel.querySelectorAll("[data-hero-slide]")];
      if (slides.length < 2) return;
      const dots = [...carousel.querySelectorAll("[data-hero-dot]")];
      const interval = parseInt(carousel.dataset.heroInterval, 10) || 10000;
      let current = 0;
      let timer = null;

      const show = (next) => {
        current = (next + slides.length) % slides.length;
        slides.forEach((s, i) => {
          const active = i === current;
          s.classList.toggle("is-active", active);
          s.setAttribute("aria-hidden", active ? "false" : "true");
          if (active) s.removeAttribute("tabindex");
          else s.setAttribute("tabindex", "-1");
        });
        dots.forEach((d, i) => {
          const active = i === current;
          d.classList.toggle("is-active", active);
          d.setAttribute("aria-selected", active ? "true" : "false");
        });
      };

      const start = () => {
        stop();
        timer = setInterval(() => show(current + 1), interval);
      };
      const stop = () => {
        if (timer) clearInterval(timer);
        timer = null;
      };

      dots.forEach((dot) => {
        dot.addEventListener("click", () => {
          show(parseInt(dot.dataset.heroIndex, 10) || 0);
          start();
        });
      });

      carousel.addEventListener("mouseenter", stop);
      carousel.addEventListener("mouseleave", start);

      // Touch swipe: a horizontal drag past the threshold changes slide and
      // suppresses the link tap that would otherwise follow. A small move is
      // treated as a normal tap so the active slide's link still works.
      let touchX = null;
      let touchY = null;
      let swiped = false;
      const SWIPE_THRESHOLD = 45;

      carousel.addEventListener("touchstart", (e) => {
        const t = e.changedTouches[0];
        touchX = t.clientX;
        touchY = t.clientY;
        swiped = false;
        stop();
      }, { passive: true });

      carousel.addEventListener("touchend", (e) => {
        if (touchX === null) return;
        const t = e.changedTouches[0];
        const dx = t.clientX - touchX;
        const dy = t.clientY - touchY;
        if (Math.abs(dx) > SWIPE_THRESHOLD && Math.abs(dx) > Math.abs(dy)) {
          swiped = true;
          show(current + (dx < 0 ? 1 : -1));
        }
        touchX = null;
        touchY = null;
        start();
      }, { passive: true });

      // Cancel the click that fires after a swipe so we don't navigate away.
      carousel.addEventListener("click", (e) => {
        if (swiped) {
          e.preventDefault();
          e.stopPropagation();
          swiped = false;
        }
      }, true);

      start();
    });

    document.addEventListener("click", (e) => {
      if (e.target.closest("[data-filter-clear]")) {
        applyFilter(null);
        return;
      }
      const btn = e.target.closest(".event-key-item[data-filter]");
      if (!btn) return;
      const isActive = btn.getAttribute("aria-pressed") === "true";
      applyFilter(isActive ? null : btn.dataset.filter);
    });

    // Preselect a filter from ?type= so links like /events/?type=workshop land
    // on the events page with that type already filtered.
    const initialType = new URLSearchParams(window.location.search).get("type");
    if (initialType && ["show", "jam", "workshop"].includes(initialType)) {
      applyFilter(initialType);
    }

  </script>
  <script src="/assets/ticket-button.js" defer></script>
</body>
</html>
