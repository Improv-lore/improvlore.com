 <div class="social-row">
  <a class="social-icon" href="{{ social.whatsapp }}" target="_blank">
    <img src="https://cdn.simpleicons.org/whatsapp/25D366" alt="WhatsApp">
  </a>
 

  
  <a class="social-icon" href="{{ social.instagram }}" target="_blank">
    <img src="https://cdn.simpleicons.org/instagram/E4405F" alt="Instagram">
  </a>
  


  <a class="social-icon" href="{{ social.youtube }}" target="_blank">
    <img src="https://cdn.simpleicons.org/youtube/FF0000" alt="YouTube">
  </a>
   <a class="social-icon" href="{{ social.gmail }}" target="_blank">
    <img src="https://cdn.simpleicons.org/gmail/FF000" alt="gmail">
  </a>
