<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  {% if pageDescription %}<meta name="description" content="{{ pageDescription }}">{% endif %}
  <link rel="canonical" href="{{ site.absUrl(canonicalUrl or page.url) }}">
  <meta property="og:title" content="{{ title }}">
  {% if pageDescription %}<meta property="og:description" content="{{ pageDescription }}">{% endif %}
  <meta property="og:url" content="{{ site.absUrl(page.url) }}">
  <meta property="og:site_name" content="{{ site.name }}">
  {% set ogImage = pageImage or "/assets/logo.png" %}
  <meta property="og:image" content="{{ site.absUrl(ogImage) }}">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="{% if pageImage %}summary_large_image{% else %}summary{% endif %}">
  <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/assets/favicon.ico" sizes="any">
  <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png">
  <link rel="manifest" href="/manifest.webmanifest">
  <link rel="alternate" type="application/atom+xml" title="Improvlore upcoming events" href="/feed.xml">
  {% if jsonLd %}<script type="application/ld+json">{{ jsonLd | safe }}</script>{% endif %}
  <link rel="stylesheet" href="/assets/css/base.css">
  <link rel="stylesheet" href="/assets/css/motifs.css">
  <link rel="stylesheet" href="/assets/css/components.css">
  <link rel="stylesheet" href="/assets/css/pages.css">
  {% if pageStyles %}{% for href in pageStyles %}<link rel="stylesheet" href="{{ href }}">{% endfor %}{% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700&family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&display=swap" rel="stylesheet">
</head>

<body>
  {# The full motif set. Each page shows only a rotating subset of these so the
     background doesn't read identically everywhere. The slice is derived from
     the page URL, so it's stable per page (no layout shift) but varies page to
     page. Index in this list maps to the motif-N positioning classes in CSS. #}
  {% set allMotifs = [
    "/assets/icons/lightning.png",
    "/assets/icons/starburst.png",
    "/assets/icons/star-purple.png",
    "/assets/icons/diamond.png",
    "/assets/icons/star-4point.png",
    "/assets/icons/moon.png",
    "/assets/icons/star-green.png",
    "/assets/icons/ring-pink.png",
    "/assets/icons/star-outline.png",
    "/assets/icons/arc-blue.png",
    "/assets/icons/arc-green.png",
    "/assets/icons/arc-pink.png",
    "/assets/icons/pacman-orange.png",
    "/assets/icons/pacman-yellow.png",
    "/assets/icons/blob-blue.png",
    "/assets/icons/blob-cream.png"
  ] %}
  {# Seed an offset from the URL length so each page starts the rotation at a
     different motif. Show 9 of the 16, wrapping around the end of the list. #}
  {% set motifSeed = (page.url | length) %}
  <div class="page-motifs" aria-hidden="true">
    {% for src in allMotifs %}
      {% set n = loop.index0 %}
      {% set shown = ((n - motifSeed) % 16 + 16) % 16 %}
      {% if shown < 9 %}
      <img class="motif motif-{{ loop.index }}" src="{{ src }}" alt="" eleventy:ignore>
      {% endif %}
    {% endfor %}
  </div>

  {# Frosted pane sitting between the animated background motifs and the page
     content, so the shapes read as a soft, blurred wash rather than competing
     with text. #}
  <div class="page-frost" aria-hidden="true"></div>

  <div class="foreground-motifs" aria-hidden="true">
    <img class="fg-motif fg-motif-lightning" src="/assets/icons/lightning.png"     alt="" eleventy:ignore>
    <img class="fg-motif fg-motif-pacman"    src="/assets/icons/pacman-yellow.png" alt="" eleventy:ignore>
  </div>

  {# Top bar: logo left, nav right. Aria labels ensure screen readers understand structure. #}
  {# "Work With Us" is the single door for audience #2 (someone vetting us for a
     corporate or festival booking). It points at /for-teams/, which pitches both
     and links on to /festivals/ as the credibility proof. Festivals keeps its
     page and footer link, just not its own top-level nav slot. #}
  {% set navLinks = [
    { url: "/", label: "Home" },
    { url: "/about/", label: "About" },
    { url: "/events/", label: "Upcoming" },
    { url: "/library/", label: "Library" },
    { url: "/for-teams/", label: "Work With Us" },
    { url: "/contact/", label: "Contact" }
  ] %}
  <header class="site-header" role="banner">
    <a class="site-header-logo" href="/" aria-label="Improv Lore home page">
      <img class="hero-logo" src="/assets/logo.png" alt="Improv Lore" eleventy:ignore>
    </a>
    {# On wide screens the links sit inline. Below the breakpoint the button
       shows and the nav collapses to a dropdown panel toggled by it. #}
    <button class="site-nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="Open menu">
      <span class="site-nav-toggle-bars" aria-hidden="true"></span>
    </button>
    <nav class="site-nav" id="site-nav" aria-label="Main navigation">
      {% for link in navLinks %}
      <a class="site-nav-link{% if page.url == link.url %} is-active{% endif %}" href="{{ link.url }}"{% if page.url == link.url %} aria-current="page"{% endif %}>{{ link.label }}</a>
      {% endfor %}
    </nav>
  </header>

  <main>
    {% if events.length > 0 or not requiresEvents %}
      {{ content | safe }}
    {% else %}
      <div class="empty-state">
        <h2>No upcoming events</h2>
        <p>join our socials in the meantime!</p>
        <p class="warning">if you think this is an error please contact us.</p>
      </div>
    {% endif %}
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-cols">
        <nav class="footer-col" aria-label="Explore">
          <h3 class="footer-col-title">Explore</h3>
          <a href="/">Home</a>
          <a href="/about/">About</a>
          <a href="/events/">Upcoming</a>
          <a href="/library/">Library</a>
          <a href="/for-teams/">Work With Us</a>
          <a href="/festivals/">Festivals</a>
          <a href="/contact/">Contact</a>
          <a href="https://underline.center" target="_blank" rel="noopener">Underline Center ↗</a>
        </nav>

        <nav class="footer-col" aria-label="Connect">
          <h3 class="footer-col-title">Connect</h3>
          <a href="{{ social.instagram }}" target="_blank" rel="noopener">Instagram</a>
          <a href="{{ social.whatsapp }}" target="_blank" rel="noopener">WhatsApp Community</a>
          <a href="{{ social.youtube }}" target="_blank" rel="noopener">YouTube</a>
          <a href="{{ social.gmail }}">Email</a>
        </nav>

        <nav class="footer-col" aria-label="Legal">
          <h3 class="footer-col-title">Legal</h3>
          <a href="/code-of-conduct/">Code of Conduct</a>
          <a href="/privacy/">Privacy</a>
          <a href="/terms/">Terms</a>
          <a href="/refunds/">Refunds</a>
        </nav>
      </div>

      <div class="footer-legal">
        <p>&copy; {{ site.year }} Improvlore. All rights reserved.</p>
        <p>Based in Bangalore, India. Questions? <a href="{{ social.gmail }}?subject=Improvlore website enquiry">{{ social.gmail | replace('mailto:', '') }}</a></p>
      </div>
    </div>
  </footer>

  <script>
    // Mobile nav: the hamburger toggles the dropdown panel. Keeps aria-expanded
    // in sync, closes on Escape, on click outside, and after a link is tapped.
    (function () {
      const toggle = document.querySelector(".site-nav-toggle");
      const nav = document.getElementById("site-nav");
      if (!toggle || !nav) return;

      const setOpen = (open) => {
        toggle.setAttribute("aria-expanded", open ? "true" : "false");
        toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
        nav.classList.toggle("is-open", open);
      };

      toggle.addEventListener("click", function () {
        setOpen(toggle.getAttribute("aria-expanded") !== "true");
      });

      nav.addEventListener("click", function (e) {
        if (e.target.closest(".site-nav-link")) setOpen(false);
      });

      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") setOpen(false);
      });

      document.addEventListener("click", function (e) {
        if (toggle.getAttribute("aria-expanded") !== "true") return;
        if (!e.target.closest(".site-header")) setOpen(false);
      });
    })();
  </script>

  <script>
    // Keep the URL's ?type= in sync with the visible filter, using
    // replaceState so changing/clearing a filter never adds a history entry.
    // This way Back leaves the events page in a single step (landing on
    // wherever you came from) instead of replaying each filter click, and the
    // URL stays shareable and reload-safe.
    const syncFilterUrl = (filter) => {
      const url = new URL(window.location.href);
      if (filter) {
        url.searchParams.set("type", filter);
      } else {
        url.searchParams.delete("type");
      }
      history.replaceState(history.state, "", url);
    };

    const applyFilter = (filter, syncUrl = true) => {
      const root = document.querySelector(".events-root");
      if (!root) return;
      root.querySelectorAll(".event-key-item[data-filter]").forEach((b) => {
        b.setAttribute("aria-pressed", b.dataset.filter === filter ? "true" : "false");
      });
      root.classList.remove("filter-show", "filter-jam", "filter-workshop");
      const clearBtn = root.querySelector("[data-filter-clear]");
      const empty = root.querySelector(".filter-empty");
      if (filter) {
        root.classList.add("filter-" + filter);
        if (clearBtn) clearBtn.hidden = false;
        if (empty) {
          const visibleCards = root.querySelectorAll(
            ".event-flip.event-type-" + filter
          ).length;
          empty.hidden = visibleCards > 0;
          const label = empty.querySelector(".filter-empty-type");
          if (label) label.textContent = filter + "s";
        }
      } else {
        if (clearBtn) clearBtn.hidden = true;
        if (empty) empty.hidden = true;
      }
      if (syncUrl) syncFilterUrl(filter);
    };

    document.addEventListener("click", (e) => {
      if (e.target.closest("[data-filter-clear]")) {
        applyFilter(null);
        return;
      }
      const btn = e.target.closest(".event-key-item[data-filter]");
      if (!btn) return;
      const isActive = btn.getAttribute("aria-pressed") === "true";
      applyFilter(isActive ? null : btn.dataset.filter);
    });

    // Preselect a filter from ?type= so links like /events/?type=workshop land
    // on the events page with that type already filtered.
    const initialType = new URLSearchParams(window.location.search).get("type");
    if (initialType && ["show", "jam", "workshop"].includes(initialType)) {
      applyFilter(initialType, false);
    }

    // Event-page back link: if you arrived from within the site, go back to the
    // exact page you came from (history.back) instead of the href fallback of
    // /events/, which is upcoming-only and may not list this event. Direct
    // landings / new tabs / external referrers keep the plain /events/ link.
    document.addEventListener("click", (e) => {
      const backLink = e.target.closest("a[data-back-link]");
      if (!backLink || e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) {
        return;
      }
      let cameFromSite = false;
      try {
        cameFromSite =
          window.history.length > 1 &&
          !!document.referrer &&
          new URL(document.referrer).origin === window.location.origin;
      } catch (err) {
        cameFromSite = false;
      }
      if (cameFromSite) {
        e.preventDefault();
        history.back();
      }
    });

  </script>
  <script src="/assets/ticket-button.js" defer></script>
  <script src="/assets/shouts.js" defer></script>
</body>
</html>
