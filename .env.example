# Copy to .env (git-ignored) and paste your Cloudflare Pages deploy hook URL.
# Dashboard: Pages project -> Settings -> Builds & deployments -> Deploy hooks.
# Used by `npm run deploy` to trigger an on-demand rebuild of the live site.
CF_DEPLOY_HOOK=https://api.cloudflare.com/client/v4/pages/webhooks/deploy_hooks/your-token-here
